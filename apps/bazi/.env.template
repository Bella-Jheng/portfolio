                # Firebase Client (公開，前端使用)
# 來源：Firebase Console → Project Settings → Your apps → Web app → SDK setup and configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Firebase Admin (私密，只在 Server 使用)
# 來源：Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Admin UID（你自己帳號的 Firebase UID，用來驗證管理員身份）
# 來源：Firebase Console → Authentication → Users → 找你的帳號 → 複製 User UID
ADMIN_UID=
NEXT_PUBLIC_ADMIN_UID=

# Gemini API Key
# 來源：https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=
